{
  "name": "polymarket-mm-bot",
  "version": "1.1.0",
  "description": "Market Making Bot for Polymarket",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "start:paper": "MODE=paper ts-node src/index.ts",
    "start:live": "MODE=live ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "clean": "rm -rf dist logs/bot-*.log data/*.json"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "@polymarket/order-utils": "^3.0.1",
    "axios": "^1.14.0",
    "dotenv": "^16.6.1",
    "ethers": "^5.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
